## 1. 先确保 id 都是字符型，避免因类型不同导致匹配失败
TCGA_BLCA_clinical_sur$id <- as.character(TCGA_BLCA_clinical_sur$id)
expr_df$id <- as.character(expr_df$id)

## 2. 找出共同的 id
common_id <- intersect(TCGA_BLCA_clinical_sur$id, expr_df$id)

## 3. 分别保留共同 id 对应的行
clinical_sub <- TCGA_BLCA_clinical_sur[TCGA_BLCA_clinical_sur$id %in% common_id, , drop = FALSE]
expr_sub <- expr_df[expr_df$id %in% common_id, , drop = FALSE]

## 4. 按 id 合并
dat_merge <- merge(clinical_sub, expr_sub, by = "id")

