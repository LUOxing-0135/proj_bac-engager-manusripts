## =========================================
## 将 expr_mat_gene_max 从“基因 × 患者”转换为“患者 × 基因”
## - 原列名（患者ID）变成第一列：id
## - 原行名（基因名）变成新的列名
## - 保留列名中的 "-"，不自动改成 "."
## =========================================

## 1. 基本检查
if (is.null(rownames(expr_mat_gene_max))) {
  stop("expr_mat_gene_max 没有行名，无法将基因名转为列名。")
}

if (is.null(colnames(expr_mat_gene_max))) {
  stop("expr_mat_gene_max 没有列名，无法提取患者 ID。")
}

## 2. 转置矩阵，并保留原始列名格式
expr_df <- as.data.frame(
  t(expr_mat_gene_max),
  check.names = FALSE,
  stringsAsFactors = FALSE
)

## 3. 将原行名（此时为患者 ID）提取为第一列 id
expr_df$id <- rownames(expr_df)

## 4. 调整列顺序，把 id 放到第一列
expr_df <- expr_df[, c("id", setdiff(colnames(expr_df), "id")), drop = FALSE]

## 5. 删除行名，避免后续与 id 列重复
rownames(expr_df) <- NULL

## 6. 检查结果
cat("expr_df 维度：", dim(expr_df), "\n")
cat("前几个患者 ID：\n")
print(head(expr_df$id))

cat("前几个基因列名：\n")
