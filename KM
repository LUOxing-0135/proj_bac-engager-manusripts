## =========================
## 1. 读取对象
## =========================
expr_mat <- `TCGA-BLCA_RNAseq_expression_matrix`
gene_anno <- `TCGA-BLCA_gene_annotation`

## =========================
## 2. 基本检查
## =========================
expr_mat <- as.matrix(expr_mat)

cat("表达矩阵维度:", dim(expr_mat), "\n")
cat("基因注释维度:", dim(gene_anno), "\n")

if (nrow(expr_mat) != nrow(gene_anno)) {
  stop("表达矩阵和基因注释的行数不一致，不能直接按行对应替换 gene_name。")
}

if (!"gene_name" %in% colnames(gene_anno)) {
  stop("gene_anno 中不存在 gene_name 列。")
}

## =========================
## 3. 提取 gene_name
## =========================
gene_name <- gene_anno$gene_name

## 去掉 gene_name 缺失或空值的行
valid_idx <- !is.na(gene_name) & gene_name != ""

expr_mat_valid <- expr_mat[valid_idx, , drop = FALSE]
gene_name_valid <- gene_name[valid_idx]

## 将 gene_name 设为行名
rownames(expr_mat_valid) <- gene_name_valid

## =========================
## 4. 对重复 gene_name 合并
##    每个样本保留最大表达值
## =========================
gene_split <- split(seq_len(nrow(expr_mat_valid)), rownames(expr_mat_valid))

expr_mat_gene_max <- t(
  sapply(gene_split, function(idx) {
    if (length(idx) == 1) {
      expr_mat_valid[idx, ]
    } else {
      apply(expr_mat_valid[idx, , drop = FALSE], 2, max, na.rm = TRUE)
    }
  })
)

expr_mat_gene_max <- as.matrix(expr_mat_gene_max)

## =========================
## 5. 检查结果
## =========================
cat("处理后表达矩阵维度:", dim(expr_mat_gene_max), "\n")
cat("前几个 gene_name:\n")
print(head(rownames(expr_mat_gene_max)))

## 查看是否还有重复 gene_name
cat("重复 gene_name 数量:", sum(duplicated(rownames(expr_mat_gene_max))), "\n")

## =========================
## 6. 保存结果
## =========================
saveRDS(
  expr_mat_gene_max,
  file = "E:/A1_Engager/data_raw/RNAseq/TCGA-BLCA_expression_by_gene_name_max.rds"
)

write.csv(
  expr_mat_gene_max,
  file = "E:/A1_Engager/data_raw/RNAseq/TCGA-BLCA_expression_by_gene_name_max.csv"
)


