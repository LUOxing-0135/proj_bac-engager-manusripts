library(survival)
library(survminer)

## 提取分析数据
dat_km <- dat_merge[, c("id", "time", "state", "CD276", "TREM2")]
dat_km <- dat_km[complete.cases(dat_km[, c("time", "state", "CD276", "TREM2")]), ]

## 类型转换
dat_km$time <- as.numeric(dat_km$time)
dat_km$state <- as.numeric(dat_km$state)
dat_km$CD276 <- as.numeric(dat_km$CD276)
dat_km$TREM2 <- as.numeric(dat_km$TREM2)

## 中位数分组
dat_km$CD276_group <- ifelse(dat_km$CD276 >= median(dat_km$CD276, na.rm = TRUE), "High", "Low")
dat_km$TREM2_group <- ifelse(dat_km$TREM2 >= median(dat_km$TREM2, na.rm = TRUE), "High", "Low")

dat_km$CD276_group <- factor(dat_km$CD276_group, levels = c("Low", "High"))
dat_km$TREM2_group <- factor(dat_km$TREM2_group, levels = c("Low", "High"))

## CD276 KM
fit_CD276 <- survfit(Surv(time, state) ~ CD276_group, data = dat_km)
